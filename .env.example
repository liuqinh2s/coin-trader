# 交易所选择: bitget / binance
EXCHANGE=bitget

# 策略切换：设为 true 启用做空策略（非龙头 + 小市值 随机选币做空），
# 默认 false 走原有做多策略。做空参数见 config.yaml 的 short_trade 段。
SHORT_STRATEGY=false

# Bitget API
BITGET_API_KEY=your_api_key_here
BITGET_API_SECRET=your_api_secret_here
BITGET_API_PASSPHRASE=your_passphrase_here

# Bitget 模拟盘（设为 true 启用，需使用模拟盘 API Key）
BITGET_DEMO=false

# Binance API
BINANCE_API_KEY=your_binance_api_key_here
BINANCE_API_SECRET=your_binance_api_secret_here

# 钉钉通知
DINGTALK_WEBHOOK=https://oapi.dingtalk.com/robot/send?access_token=your_token_here
DINGTALK_SECRET=your_secret_here

# CoinGecko 市值数据（免费 Demo Key，绑定到 key 而非 IP，绕开共享 IP 限流）
COINGECKO_DEMO_API_KEY=your_coingecko_demo_api_key_here

# 代理（可选）
NEED_PROXY=false
PROXY_HOST=127.0.0.1
PROXY_PORT=7890
